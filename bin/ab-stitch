#!/usr/bin/env bash
# Thin launcher for the AB Video Stitcher CLI.
#
# Resolves its own real location (following symlinks) so it works from anywhere
# and when symlinked onto your PATH, then forwards every argument to
# video_stitcher.py. Override the interpreter with PYTHON=/path/to/python3.
#
#   ./bin/ab-stitch /path/to/clips --canvas 1080p
#   ln -s "$PWD/bin/ab-stitch" /usr/local/bin/ab-stitch   # then: ab-stitch …
set -euo pipefail

src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do                      # resolve symlinks to the real file
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [[ $src != /* ]] && src="$dir/$src"
done
root="$(cd -P "$(dirname "$src")/.." && pwd)"

exec "${PYTHON:-python3}" "$root/video_stitcher.py" "$@"
